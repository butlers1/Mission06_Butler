@model Mission06_Butler.Models.Movie
@{
    ViewData["Title"] = "Delete Movie";
}

<div class="text-center">
    <h2>Confirm Deletion</h2>
    <h3>Are you sure you want to delete the record for "@Model.Title"?</h3>

    <div class="mt-4">
        <form method="post" asp-action="Delete">
            @* The ID is passed as a hidden field so the controller knows which movie to remove *@
            <input type="hidden" asp-for="MovieId" />

            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>